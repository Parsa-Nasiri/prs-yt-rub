# ══════════════════════════════════════════════════
#   Rubika Multi-Tool Bot — Environment Variables
#   Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════

# ── Required ─────────────────────────────────────
# Get your bot token from Rubika BotFather
BOT_TOKEN=your_rubika_bot_token_here

# ── GitHub Actions Auto-Restart ───────────────────
# Automatically provided by GitHub Actions as ${{ secrets.GITHUB_TOKEN }}
# Add it as a repository secret for manual runs
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPOSITORY=Parsa-Nasiri/prs-yt-rub
GITHUB_BRANCH=main
GITHUB_WORKFLOW_FILE=bot.yml

# ── Optional: Admins ──────────────────────────────
# Comma-separated Rubika chat IDs to notify on restart
ADMIN_IDS=u123456789,u987654321

# ── Predefined Config Channels (Telegram) ─────────
# Comma-separated public Telegram channel usernames (no @)
CONFIG_CHANNELS=proxy_kafee,ConfigX2ray,saministamm

# ── Download Limits ───────────────────────────────
MAX_VIDEO_SIZE_MB=3072
MAX_FILE_SIZE_MB=3072

# ── Runtime (seconds before auto-restart) ─────────
# Default: 5h 40min = 20400 seconds
MAX_RUNTIME_SECONDS=20400

# ── Telegram Monitor Poll Interval (seconds) ──────
MONITOR_POLL_INTERVAL=120
